---
layout: layouts/base.njk
title: "Générateur"
description: "Générateur de fichiers Markdown pour ressources et guides LIBRAW."
permalink: /generator/
---

<div class="gen-wrapper">

  <div class="gen-header">
    <div class="gen-title-row">
      <span class="prefix">//</span>
      <h1 class="gen-title">générateur</h1>
    </div>
    <p class="gen-subtitle">Crée, importe et exporte des fiches Markdown pour le repo.</p>
  </div>

  {# ─── Mode switcher + actions ─────────────────────────────────── #}
  <div class="gen-mode-bar">
    <button class="gen-mode-btn active" data-mode="ressource" id="btn-ressource">
      <span class="mode-icon">🔧</span> ressource
    </button>
    <button class="gen-mode-btn" data-mode="guide" id="btn-guide">
      <span class="mode-icon">📖</span> guide
    </button>
    <div class="gen-mode-spacer"></div>
    <label class="gen-action-btn gen-import-btn" for="gen-upload-input" title="Importer un .md existant">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
      importer
      <input type="file" id="gen-upload-input" accept=".md,text/markdown,text/plain" style="display:none" />
    </label>
  </div>

  {# ─── Toast ────────────────────────────────────────────────────── #}
  <div class="gen-toast hidden" id="gen-toast"></div>

  <div class="gen-body">

    {# ─── Formulaire ─────────────────────────────────────────────── #}
    <div class="gen-form-col">

      {# ══ RESSOURCE FORM ══ #}
      <form class="gen-form" id="form-ressource" autocomplete="off">

        <div class="form-group">
          <label class="form-label" for="r-title">title <span class="req">*</span></label>
          <input class="form-input" id="r-title" type="text" placeholder="uBlock Origin" />
        </div>

        <div class="form-group">
          <label class="form-label" for="r-description">description <span class="req">*</span></label>
          <textarea class="form-input form-textarea" id="r-description" rows="2" placeholder="Le bloqueur de pub le plus efficace. Open-source..."></textarea>
        </div>

        <div class="form-group">
          <label class="form-label" for="r-url">url <span class="req">*</span></label>
          <input class="form-input" id="r-url" type="url" placeholder="https://ublockorigin.com" />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="r-categorie">catégorie <span class="req">*</span></label>
            <select class="form-input form-select" id="r-categorie">
              <option value="outils">🔧 outils</option>
              <option value="streaming">📺 streaming</option>
              <option value="download">⬇️ download</option>
              <option value="privacy">🔒 privacy</option>
              <option value="gaming">🎮 gaming</option>
              <option value="ia">🤖 ia</option>
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="r-niveau">niveau <span class="req">*</span></label>
            <select class="form-input form-select" id="r-niveau">
              <option value="debutant">👶 débutant</option>
              <option value="avance">🧠 avancé</option>
              <option value="expert">⚡ expert</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="r-date-verif">date vérif</label>
            <input class="form-input" id="r-date-verif" type="text" placeholder="05/2026" maxlength="7" />
          </div>
          <div class="form-group form-group--check">
            <label class="form-label">options</label>
            <div class="check-row">
              <label class="check-label"><input type="checkbox" id="r-verifie" checked /><span>vérifié</span></label>
              <label class="check-label"><input type="checkbox" id="r-featured" /><span>featured</span></label>
              <label class="check-label"><input type="checkbox" id="r-starred" /><span>⭐ starred</span></label>
              <label class="check-label"><input type="checkbox" id="r-draft" /><span>draft</span></label>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="r-tags">tags <span class="hint">(séparés par des virgules)</span></label>
          <input class="form-input" id="r-tags" type="text" placeholder="extension, adblock, navigateur" />
        </div>

        <div class="form-group">
          <label class="form-label" for="r-badges">badges <span class="hint">(emojis séparés par des espaces)</span></label>
          <input class="form-input" id="r-badges" type="text" placeholder="⚡ 🧠" />
        </div>

        <div class="form-group">
          <label class="form-label" for="r-guide">lien guide <span class="hint">(optionnel)</span></label>
          <input class="form-input" id="r-guide" type="text" placeholder="/guides/guide-ublock/" />
        </div>

      </form>

      {# ══ GUIDE FORM ══ #}
      <form class="gen-form hidden" id="form-guide" autocomplete="off">

        <div class="form-group">
          <label class="form-label" for="g-title">title <span class="req">*</span></label>
          <input class="form-input" id="g-title" type="text" placeholder="uBlock Origin : config optimale" />
        </div>

        <div class="form-group">
          <label class="form-label" for="g-description">description <span class="req">*</span></label>
          <textarea class="form-input form-textarea" id="g-description" rows="2" placeholder="Installation, listes de filtres, mode avancé..."></textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="g-date">date <span class="req">*</span></label>
            <input class="form-input" id="g-date" type="date" />
          </div>
          <div class="form-group">
            <label class="form-label" for="g-categorie">catégorie <span class="req">*</span></label>
            <select class="form-input form-select" id="g-categorie">
              <option value="outils">🔧 outils</option>
              <option value="streaming">📺 streaming</option>
              <option value="download">⬇️ download</option>
              <option value="privacy">🔒 privacy</option>
              <option value="gaming">🎮 gaming</option>
              <option value="ia">🤖 ia</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="g-niveau">niveau <span class="req">*</span></label>
            <select class="form-input form-select" id="g-niveau">
              <option value="debutant">👶 débutant</option>
              <option value="avance">🧠 avancé</option>
              <option value="expert">⚡ expert</option>
            </select>
          </div>
          <div class="form-group form-group--check">
            <label class="form-label">draft</label>
            <div class="check-row">
              <label class="check-label"><input type="checkbox" id="g-draft" /><span>draft</span></label>
            </div>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="g-tags">tags <span class="hint">(séparés par des virgules)</span></label>
          <input class="form-input" id="g-tags" type="text" placeholder="ublock, adblock, privacy, navigateur" />
        </div>

        <div class="form-group">
          <label class="form-label" for="g-body">contenu Markdown <span class="hint">(optionnel — squelette généré si vide)</span></label>
          <textarea class="form-input form-textarea form-textarea--lg" id="g-body" rows="10" placeholder="## Pourquoi X&#10;&#10;Contenu ici..."></textarea>
        </div>

      </form>

      <div class="gen-filename-row">
        <span class="gen-filename-label">// fichier</span>
        <span class="gen-filename-value" id="gen-filename">—</span>
      </div>

    </div>

    {# ─── Aperçu ──────────────────────────────────────────────── #}
    <div class="gen-preview-col">

      <div class="gen-preview-header">
        <span class="gen-preview-label">// aperçu markdown</span>
        <div class="gen-preview-actions">
          <button class="gen-action-btn" id="gen-copy-btn" title="Copier dans le presse-papier">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            <span id="copy-text">copier</span>
          </button>
          <button class="gen-action-btn gen-export-btn" id="gen-download-btn" title="Télécharger le fichier .md">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <span id="dl-text">exporter</span>
          </button>
        </div>
      </div>

      <div class="gen-preview-split">
        <pre class="gen-code-block"><code id="gen-code">— remplis le formulaire</code></pre>
        <div class="gen-card-preview">
          <div class="preview-label">// rendu carte</div>
          <div id="card-preview-inner"><p class="preview-empty">— aperçu disponible après saisie</p></div>
        </div>
      </div>

    </div>
  </div>
</div>

{% block scripts %}
<script>
(function () {
  'use strict';
  let mode = 'ressource';

  const btnRessource  = document.getElementById('btn-ressource');
  const btnGuide      = document.getElementById('btn-guide');
  const formRessource = document.getElementById('form-ressource');
  const formGuide     = document.getElementById('form-guide');
  const genCode       = document.getElementById('gen-code');
  const genFilename   = document.getElementById('gen-filename');
  const copyBtn       = document.getElementById('gen-copy-btn');
  const copyText      = document.getElementById('copy-text');
  const dlBtn         = document.getElementById('gen-download-btn');
  const dlText        = document.getElementById('dl-text');
  const uploadInput   = document.getElementById('gen-upload-input');
  const cardPreview   = document.getElementById('card-preview-inner');
  const toast         = document.getElementById('gen-toast');

  // ─── Helpers ──────────────────────────────────────────────────
  const val    = id => { const e = document.getElementById(id); return e ? e.value.trim() : ''; };
  const chk    = id => { const e = document.getElementById(id); return e ? e.checked : false; };
  const setVal = (id, v) => { const e = document.getElementById(id); if (e) e.value = v ?? ''; };
  const setChk = (id, v) => { const e = document.getElementById(id); if (e) e.checked = !!v; };
  const setSel = (id, v) => {
    const e = document.getElementById(id); if (!e || !v) return;
    if ([...e.options].some(o => o.value === v)) e.value = v;
  };
  const slugify     = s => s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9]+/g,'-').replace(/(^-|-$)/g,'');
  const parseTags   = s => s.split(',').map(t=>t.trim()).filter(Boolean);
  const parseBadges = s => s.split(' ').map(t=>t.trim()).filter(Boolean);
  const todayISO    = () => new Date().toISOString().slice(0,10);
  const niveauLabel = n => ({debutant:'👶 débutant',avance:'🧠 avancé',expert:'⚡ expert'})[n]||n;
  const niveauClass = n => ({debutant:'niveau-debutant',avance:'niveau-avance',expert:'niveau-expert'})[n]||'';
  const catLabel    = c => ({streaming:'📺 Streaming',download:'⬇️ Download',outils:'🔧 Outils',privacy:'🔒 Privacy',gaming:'🎮 Gaming',ia:'🤖 IA'})[c]||c;

  // ─── Toast ────────────────────────────────────────────────────
  let toastTimer;
  function showToast(msg, type='ok') {
    toast.textContent = msg;
    toast.className = 'gen-toast gen-toast--' + type;
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.add('hidden'), 3200);
  }

  function flashBtn(btn, textEl, label, ms=2000) {
    btn.classList.add('active-flash');
    const orig = textEl.textContent;
    textEl.textContent = label;
    setTimeout(() => { textEl.textContent = orig; btn.classList.remove('active-flash'); }, ms);
  }

  // ─── Build Markdown ───────────────────────────────────────────
  function buildRessource() {
    const title=val('r-title'),desc=val('r-description'),url=val('r-url'),cat=val('r-categorie'),niveau=val('r-niveau'),dateVerif=val('r-date-verif'),verifie=chk('r-verifie'),featured=chk('r-featured'),draft=chk('r-draft');
    const tags=parseTags(val('r-tags')),badges=parseBadges(val('r-badges')),guide=val('r-guide'),starred=chk('r-starred');
    const tagsYaml=tags.length?'\ntags:\n'+tags.map(t=>`  - ${t}`).join('\n'):'';
    const badgesYaml=badges.length?'\nbadges:\n'+badges.map(b=>`  - ${b}`).join('\n'):'';
    const guideYaml=guide?`\nguide: ${guide}`:'';
    const verifYaml=verifie?`\nverifie: true\ndate_verif: "${dateVerif||todayISO().slice(0,7).replace('-','/')}"` :'';
    return `---\ntitle: "${title||'Titre'}"\ndescription: "${desc||'Description.'}"\nurl: "${url||'https://'}"\ncategorie: ${cat}${tagsYaml}\nniveau: ${niveau}${verifYaml}\nfeatured: ${featured}\nstarred: ${starred}${badgesYaml}${guideYaml}\ndraft: ${draft}\n---`;
  }

  function buildGuide() {
    const title=val('g-title'),desc=val('g-description'),date=val('g-date')||todayISO(),cat=val('g-categorie'),niveau=val('g-niveau'),draft=chk('g-draft');
    const tags=parseTags(val('g-tags')),body=val('g-body');
    const tagsYaml=tags.length?'\ntags:\n'+tags.map(t=>`  - ${t}`).join('\n'):'';
    const defaultBody=`\n## Pourquoi ${title||'ce guide existe'}\n\nExplique ici le contexte.\n\n## Installation\n\n\`\`\`bash\n# commande ici\n\`\`\`\n\n## Configuration\n\nDétails de config.\n\n## Ce que ça ne fait pas\n\nLimites.`;
    return `---\ntitle: "${title||'Titre'}"\ndescription: "${desc||'Description.'}"\ndate: ${date}\ncategorie: ${cat}\nniveau: ${niveau}${tagsYaml}\ndraft: ${draft}\n---\n${body||defaultBody}`;
  }

  const getMd = () => mode==='ressource' ? buildRessource() : buildGuide();
  const getFilename = () => {
    const t = mode==='ressource' ? val('r-title') : val('g-title');
    if (!t) return '—';
    return (mode==='guide'?'guide-':'') + slugify(t) + '.md';
  };

  // ─── Aperçus ──────────────────────────────────────────────────
  function renderCardRessource() {
    const title=val('r-title')||'—',desc=val('r-description')||'—',url=val('r-url')||'#',niveau=val('r-niveau');
    const tags=parseTags(val('r-tags')).slice(0,3),badges=parseBadges(val('r-badges'));
    const verifie=chk('r-verifie'),dv=val('r-date-verif'),guide=val('r-guide'),feat=chk('r-featured');
    const tagsHtml=tags.map(t=>`<span class="tag">${t}</span>`).join('');
    const verifHtml=verifie?`<span class="badge-verif">✅ ${dv||'—'}</span>`:'';
    const guideHtml=guide?`<a href="${guide}" class="row-link">guide →</a>`:'';
    const featBadge=feat?`<span class="gen-featured-badge">★ featured</span>`:'';
    return `${featBadge}
    <div class="ressource-row" style="border:none;padding:0.5rem 0;flex-wrap:wrap;gap:0.4rem">
      <div class="row-main" style="flex-direction:column;gap:0.1rem;width:100%">
        <a href="${url}" class="row-title" target="_blank" rel="noopener noreferrer">${title}</a>
        <span class="row-desc" style="display:block;white-space:normal">${desc}</span>
      </div>
      <div class="row-tags" style="width:100%">
        <span class="niveau-badge ${niveauClass(niveau)}">${niveauLabel(niveau)}</span>
        ${tagsHtml}
      </div>
      <div class="row-meta">${verifHtml}</div>
      <div class="row-actions" style="margin-left:auto">${guideHtml}<a href="${url}" class="row-link primary" target="_blank" rel="noopener noreferrer">visiter ↗</a></div>
    </div>`;
  }

  function renderCardGuide() {
    const title=val('g-title')||'—',desc=val('g-description')||'—',niveau=val('g-niveau'),cat=val('g-categorie');
    const tags=parseTags(val('g-tags')).slice(0,3);
    const tagsHtml=tags.map(t=>`<span class="tag">${t}</span>`).join('');
    return `<a href="#" class="guide-row" style="text-decoration:none">
      <div class="guide-row-main">
        <span class="guide-row-title">${title}</span>
        <span class="guide-row-desc">${desc}</span>
      </div>
      <div class="guide-row-meta">
        <span class="niveau-badge ${niveauClass(niveau)}">${niveauLabel(niveau)}</span>
        <span class="guide-row-cat">${catLabel(cat)}</span>
        ${tagsHtml}
      </div>
      <span class="guide-row-arrow">→</span>
    </a>`;
  }

  // ─── Update ───────────────────────────────────────────────────
  function update() {
    genCode.textContent = getMd();
    genFilename.textContent = getFilename();
    cardPreview.innerHTML = mode==='ressource' ? renderCardRessource() : renderCardGuide();
  }

  function setMode(m) {
    mode = m;
    btnRessource.classList.toggle('active', m==='ressource');
    btnGuide.classList.toggle('active', m==='guide');
    formRessource.classList.toggle('hidden', m!=='ressource');
    formGuide.classList.toggle('hidden', m!=='guide');
    update();
  }

  btnRessource.addEventListener('click', () => setMode('ressource'));
  btnGuide.addEventListener('click', () => setMode('guide'));
  document.querySelectorAll('.gen-form input,.gen-form select,.gen-form textarea')
    .forEach(el => { el.addEventListener('input', update); el.addEventListener('change', update); });

  // ─── Copier ───────────────────────────────────────────────────
  copyBtn.addEventListener('click', () => {
    const md = getMd();
    const doFlash = () => { flashBtn(copyBtn, copyText, 'copié ✓'); showToast('✓ Markdown copié dans le presse-papier.'); };
    if (navigator.clipboard) {
      navigator.clipboard.writeText(md).then(doFlash).catch(() => {
        // fallback
        const ta = Object.assign(document.createElement('textarea'), {value:md});
        ta.style.cssText = 'position:fixed;opacity:0';
        document.body.appendChild(ta); ta.select(); document.execCommand('copy');
        document.body.removeChild(ta); doFlash();
      });
    } else {
      const ta = Object.assign(document.createElement('textarea'), {value:md});
      ta.style.cssText = 'position:fixed;opacity:0';
      document.body.appendChild(ta); ta.select(); document.execCommand('copy');
      document.body.removeChild(ta); doFlash();
    }
  });

  // ─── Exporter ─────────────────────────────────────────────────
  dlBtn.addEventListener('click', () => {
    const filename = getFilename();
    if (filename === '—') { showToast('⚠ Remplis au moins le titre.', 'err'); return; }
    const blob = new Blob([getMd()], {type:'text/markdown;charset=utf-8'});
    const url  = URL.createObjectURL(blob);
    const a    = Object.assign(document.createElement('a'), {href:url, download:filename});
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    URL.revokeObjectURL(url);
    flashBtn(dlBtn, dlText, 'exporté ✓');
    showToast(`✓ Fichier exporté : ${filename}`);
  });

  // ─── Parser frontmatter ───────────────────────────────────────
  function parseFrontmatter(raw) {
    const match = raw.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);
    if (!match) return {fm:{}, body:''};
    const fm={}, body=match[2].trim();
    let currentKey=null;
    for (const line of match[1].split('\n')) {
      const listMatch = line.match(/^ {2}- (.+)$/);
      if (listMatch && currentKey) {
        const item = listMatch[1].replace(/^["']|["']$/g,'').trim();
        if (!Array.isArray(fm[currentKey])) fm[currentKey]=[];
        fm[currentKey].push(item); continue;
      }
      const kv = line.match(/^([a-zA-Z_]\w*):\s*(.*)$/);
      if (!kv) continue;
      const [,key,rawVal]=kv; currentKey=key;
      const v=rawVal.replace(/^["']|["']$/g,'').trim();
      fm[key] = v===''?[]:v==='true'?true:v==='false'?false:v;
    }
    return {fm, body};
  }

  function detectType(fm) {
    if (fm.url && !fm.date) return 'ressource';
    if (fm.date && !fm.url) return 'guide';
    return fm.url ? 'ressource' : 'guide';
  }

  function populateRessource(fm) {
    setVal('r-title', fm.title||''); setVal('r-description', fm.description||''); setVal('r-url', fm.url||'');
    setSel('r-categorie', fm.categorie); setSel('r-niveau', fm.niveau); setVal('r-date-verif', fm.date_verif||'');
    setChk('r-verifie', fm.verifie!==undefined?fm.verifie:true); setChk('r-featured', !!fm.featured); setChk('r-starred', !!fm.starred); setChk('r-draft', !!fm.draft);
    setVal('r-tags', Array.isArray(fm.tags)?fm.tags.join(', '):(fm.tags||''));
    setVal('r-badges', Array.isArray(fm.badges)?fm.badges.join(' '):(fm.badges||''));
    setVal('r-guide', fm.guide||'');
  }

  function populateGuide(fm, body) {
    setVal('g-title', fm.title||''); setVal('g-description', fm.description||'');
    setVal('g-date', fm.date?String(fm.date).slice(0,10):todayISO());
    setSel('g-categorie', fm.categorie); setSel('g-niveau', fm.niveau); setChk('g-draft', !!fm.draft);
    setVal('g-tags', Array.isArray(fm.tags)?fm.tags.join(', '):(fm.tags||''));
    setVal('g-body', body||'');
  }

  // ─── Importer ─────────────────────────────────────────────────
  uploadInput.addEventListener('change', e => {
    const file = e.target.files[0]; if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const raw = ev.target.result;
        if (!raw.trimStart().startsWith('---')) { showToast('⚠ Fichier invalide : frontmatter YAML manquant (---)', 'err'); return; }
        const {fm, body} = parseFrontmatter(raw);
        const type = detectType(fm);
        setMode(type);
        if (type==='ressource') { populateRessource(fm); showToast(`✓ Ressource importée : ${fm.title||file.name}`); }
        else { populateGuide(fm, body); showToast(`✓ Guide importé : ${fm.title||file.name}`); }
        update();
      } catch(err) { showToast('⚠ Erreur de parsing : '+err.message, 'err'); }
      uploadInput.value='';
    };
    reader.readAsText(file, 'utf-8');
  });

  // ─── Init ─────────────────────────────────────────────────────
  document.getElementById('g-date').value = todayISO();
  update();
})();
</script>
{% endblock %}
