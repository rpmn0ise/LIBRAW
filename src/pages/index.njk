---
layout: layouts/base.njk
title: false
description: "Bibliothèque FR ultra-sélective d'outils et guides pour utilisateurs tech. Streaming, download, privacy, émulation — sélection vérifiée manuellement."
permalink: /
---

{# ─── Hero ──────────────────────────────────────────────────────── #}
<section class="hero">
  <div class="hero-eyebrow">
    <span class="hero-dot"></span>
    <span class="hero-eyebrow-text">sélection vérifiée manuellement · aucun sponsor</span>
  </div>
  <h1 class="hero-title">
    La bibliothèque FR<br>
    <span>qui ne bullshite pas.</span>
  </h1>
  <p class="hero-tagline">
    Outils vérifiés manuellement. Guides directs. Aucune pub, aucun affilié, aucun annuaire gonflé à l'air.
  </p>
  <div class="hero-stats">
    <div class="hero-stat">
      <strong>{{ collections.ressources | length }}</strong>
      <span>ressources</span>
    </div>
    <span class="hero-stat-sep"></span>
    <div class="hero-stat">
      <strong>{{ site.categories | length }}</strong>
      <span>catégories</span>
    </div>
    <span class="hero-stat-sep"></span>
    <div class="hero-stat">
      <strong>{{ collections.guides | length }}</strong>
      <span>guides</span>
    </div>
    <span class="hero-stat-sep"></span>
    <div class="hero-stat">
      <strong>{{ env.buildDate }}</strong>
      <span>màj</span>
    </div>
  </div>
</section>


{# ─── Starred (indispensables) ──────────────────────────────────── #}
{% if collections.ressourcesStarred | length %}
<section class="section">
  <div class="section-header">
    <div class="section-title-group">
      <span class="section-label">// incontournables</span>
      <span class="section-title">⭐ Indispensables</span>
    </div>
    <span class="starred-badge-count">{{ collections.ressourcesStarred | length }} ressources</span>
  </div>

  <div class="ressource-list ressource-list--starred">
    {% for item in collections.ressourcesStarred %}
    <div class="ressource-row"
         data-title="{{ item.data.title | lower }}"
         data-description="{{ item.data.description | lower }}"
         data-categorie="{{ item.data.categorie }}"
         data-niveau="{{ item.data.niveau }}"
         data-starred="true">
      <span class="row-star" title="Indispensable">⭐</span>
      <div class="row-main">
        <a href="{{ item.data.url }}" class="row-title" target="_blank" rel="noopener noreferrer">{{ item.data.title }}</a>
        <span class="row-desc">{{ item.data.description }}</span>
      </div>
      <div class="row-tags">
        {% if item.data.niveau %}
        <span class="niveau-badge {{ item.data.niveau | niveauClass }}">{{ item.data.niveau | niveauLabel }}</span>
        {% endif %}
        {% if item.data.tags %}
          {% for tag in item.data.tags | limit(2) %}<span class="tag">{{ tag }}</span>{% endfor %}
        {% endif %}
      </div>
      <div class="row-meta">
        {% if item.data.verifie %}<span class="row-verif">✅ {{ item.data.date_verif }}</span>{% endif %}
      </div>
      <div class="row-actions">
        {% if item.data.guide %}<a href="{{ item.data.guide }}" class="row-link">guide →</a>{% endif %}
        <a href="{{ item.data.url }}" class="row-link primary" target="_blank" rel="noopener noreferrer">visiter ↗</a>
      </div>
    </div>
    {% endfor %}
  </div>
</section>
{% endif %}

{# ─── Catégories ─────────────────────────────────────────────────── #}
<section class="section">
  <div class="section-header">
    <div class="section-title-group">
      <span class="section-label">Navigation</span>
      <span class="section-title">Catégories</span>
    </div>
  </div>

  <div class="cat-grid">
    {% for cat in site.categories %}
    {% set catCount = collections["ressources_" + cat.slug] | length %}
    <a href="/categories/{{ cat.slug }}/" class="cat-card">
      <span class="cat-emoji">{{ cat.emoji }}</span>
      <div class="cat-body">
        <div class="cat-name">{{ cat.label }}</div>
        <span class="cat-count">{{ catCount }} ressource{% if catCount > 1 %}s{% endif %}</span>
      </div>
    </a>
    {% endfor %}
  </div>
</section>

{# ─── Essentiels (lignes) ─────────────────────────────────────────── #}
<section class="section">
  <div class="section-header">
    <div class="section-title-group">
      <span class="section-label">Sélection immédiate</span>
      <span class="section-title">Essentiels</span>
    </div>
    <span class="section-count" style="font-family:var(--font-mono);font-size:0.7rem;color:var(--text-dim);">
      {{ collections.ressourcesFeatured | length }} ressources
    </span>
  </div>

  <div class="ressource-list">
    {% for item in collections.ressourcesFeatured %}
    <div class="ressource-row"
         data-title="{{ item.data.title | lower }}"
         data-description="{{ item.data.description | lower }}"
         data-categorie="{{ item.data.categorie }}"
         data-niveau="{{ item.data.niveau }}"
         data-starred="{{ item.data.starred }}">
      {% if item.data.starred %}
      <span class="row-star" title="Indispensable">⭐</span>
      {% elif item.data.badges and item.data.badges.length %}
      <span class="row-badge">{{ item.data.badges[0] }}</span>
      {% endif %}
      <div class="row-main">
        <a href="{{ item.data.url }}" class="row-title" target="_blank" rel="noopener noreferrer">{{ item.data.title }}</a>
        <span class="row-desc">{{ item.data.description }}</span>
      </div>
      <div class="row-tags">
        {% if item.data.niveau %}
        <span class="niveau-badge {{ item.data.niveau | niveauClass }}">{{ item.data.niveau | niveauLabel }}</span>
        {% endif %}
        {% if item.data.tags %}
          {% for tag in item.data.tags | limit(2) %}
          <span class="tag">{{ tag }}</span>
          {% endfor %}
        {% endif %}
      </div>
      <div class="row-meta">
        {% if item.data.verifie %}
        <span class="row-verif">✅ {{ item.data.date_verif }}</span>
        {% endif %}
      </div>
      <div class="row-actions">
        {% if item.data.guide %}
        <a href="{{ item.data.guide }}" class="row-link">guide →</a>
        {% endif %}
        <a href="{{ item.data.url }}" class="row-link primary" target="_blank" rel="noopener noreferrer">visiter ↗</a>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

{# ─── Guides récents ─────────────────────────────────────────────── #}
<section class="section">
  <div class="section-header">
    <div class="section-title-group">
      <span class="section-label">Guides pratiques</span>
      <span class="section-title">Guides récents</span>
    </div>
    <a href="/guides/" class="section-link">voir tous →</a>
  </div>

  <div class="guide-list">
    {% for guide in collections.guidesFeatured %}
    <a href="{{ guide.url }}" class="guide-row">
      <div class="guide-row-main">
        <span class="guide-row-title">{{ guide.data.title }}</span>
        {% if guide.data.description %}
        <span class="guide-row-desc">{{ guide.data.description }}</span>
        {% endif %}
      </div>
      <div class="guide-row-meta">
        <span class="niveau-badge {{ guide.data.niveau | niveauClass }}">{{ guide.data.niveau | niveauLabel }}</span>
        <span class="guide-row-cat">{{ guide.data.categorie | categorieLabel }}</span>
      </div>
      <span class="guide-row-arrow">→</span>
    </a>
    {% endfor %}
  </div>
</section>
